%%{init: {"theme":"neutral","themeVariables":{"fontSize":"40px"}}}%%
flowchart LR
    Entry((" "))
    Geom["Geometry"]
    Attr(["Attribute"])
    Vol[("Volume")]
    Proc["AttributeProcess"]
    Conv["Converter"]

    Entry --> Geom
    Geom -.-> Attr
    Attr -.-> Vol
    Vol --> Proc
    Proc -.-> Conv

    linkStyle 3 stroke:transparent,fill:none

    class Entry entryPoint
    class Geom rootNode
    class Attr attributeNode
    class Vol volumeNode
    class Proc attributeProcessNode
    class Conv converterNode

    classDef entryPoint fill:#102A43,stroke:#102A43,stroke-width:2px,color:#102A43;
    classDef rootNode fill:#DFF5F1,stroke:#124559,stroke-width:4px,color:#102A43;
    classDef attributeNode fill:#FDECF3,stroke:#B83280,stroke-width:2.5px,color:#702459;
    classDef volumeNode fill:#E2E8F0,stroke:#475569,stroke-width:2.5px,color:#1E293B;
    classDef attributeProcessNode fill:#FDECF3,stroke:#B83280,stroke-width:4px,color:#702459;
    classDef converterNode fill:#FEE2E2,stroke:#C53030,stroke-width:2.5px,color:#742A2A;
